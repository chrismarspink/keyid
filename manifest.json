{
  "name": "KeyID — 디지털 신원",
  "short_name": "KeyID",
  "description": "PKI 기반 디지털 신원 인증 — 서명, 암호화, 검증",
  "id": "/keyid/",
  "start_url": "/keyid/",
  "scope": "/keyid/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#1e2433",
  "theme_color": "#141926",
  "lang": "ko",
  "categories": ["productivity", "utilities"],
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "screenshots": [],
  "file_handlers": [
    {
      "action": "/keyid/file/sign",
      "accept": { "application/pkis": [".pkis"] },
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    },
    {
      "action": "/keyid/file/cert",
      "accept": { "application/pkis-cert": [".pkis-cert"] },
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    },
    {
      "action": "/keyid/file/request",
      "accept": { "application/pkis-req": [".pkis-req"] },
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    },
    {
      "action": "/keyid/file/key",
      "accept": { "application/pkis-key": [".pkis-key"] },
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    },
    {
      "action": "/keyid/file/verify",
      "accept": { "application/pkis-sig": [".pkis-sig"] },
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    }
  ],
  "share_target": {
    "action": "/keyid/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["application/pkis", ".pkis", ".pkis-cert", ".pkis-sig", ".pkis-req", ".pkis-key"]
        }
      ]
    }
  },
  "protocol_handlers": [
    { "protocol": "web+keyid", "url": "/keyid/protocol?url=%s" }
  ]
}
