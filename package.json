{
  "name": "keyid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev --host",
    "dev:mobile": "concurrently \"vite dev --host\" \"npx ngrok http 5173\"",
    "build": "vite build",
    "deploy": "NODE_ENV=production npm run build && touch build/.nojekyll && cp build/index.html build/404.html && gh-pages -d build --dotfiles",
    "preview": "vite preview --host",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.32",
    "svelte": "^4.0.0",
    "svelte-check": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.19.0",
    "workbox-window": "^7.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "asn1js": "^3.0.5",
    "bc-ur": "^0.1.6",
    "jsqr": "^1.4.0",
    "pdfjs-dist": "^5.5.207",
    "pkijs": "^3.2.4",
    "qrcode": "^1.5.4"
  },
  "type": "module"
}
